{
  "name": "peos-application",
  "version": "1.0.0",
  "description": "PEOS desktop application",
  "main": "electron/main.js",
  "scripts": {
    "build": "tailwindcss -i ./resources/css/app.css -o ./public/css/app.css",
    "dev": "tailwindcss -i ./resources/css/app.css -o ./public/css/app.css --watch",
    "start": "npx serve public",
    "simplify-peos": ".\\.venv\\Scripts\\python.exe scripts\\simplify_peos.py",
    "migrate:mysql-dump": "node scripts/migrate-mysql-dump-to-sqlite.js",
    "electron": "electron .",
    "dist": "npm run build && node electron/pack.js"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^14.0.0"
  }
}
